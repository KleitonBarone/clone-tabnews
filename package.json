{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação do https://www.tabnews.com.br para aprendizado",
  "scripts": {
    "dev": "node infra/scripts/dev-setup.js",
    "test": "npm run services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "test:once": "jest --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migrations:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "migrations:up:dry": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development --dry-run up",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:hook": "biome check",
    "secret:check": "secretlint '**/*'",
    "commitlint": "commitlint",
    "githook": "lint-staged",
    "prepare": "husky",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*": [
      "npm run lint:hook",
      "npm run secret:check"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "license": "MIT",
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "^3.0.3",
    "cookie": "1.1.1",
    "next": "14.2.35",
    "next-connect": "1.0.0",
    "node-pg-migrate": "7.9.1",
    "nodemailer": "7.0.13",
    "pg": "8.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.4.1",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@faker-js/faker": "9.9.0",
    "@secretlint/secretlint-rule-preset-recommend": "9.3.4",
    "@types/jest": "29.5.14",
    "@types/node": "^24.13.2",
    "commitizen": "4.3.2",
    "concurrently": "8.2.2",
    "cross-spawn": "7.0.6",
    "cz-conventional-changelog": "3.3.0",
    "dotenv": "16.6.1",
    "dotenv-expand": "11.0.7",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "15.5.2",
    "secretlint": "9.3.4",
    "set-cookie-parser": "2.7.2",
    "typescript": "^5.9.3"
  }
}
